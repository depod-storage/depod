# Depod Configuration
# ============================================================================
# This file is an example configuration for development.
#
# Copy this file to `.env` and replace the placeholder values:
#
#     cp .env.example .env
#
# Never commit `.env` or production secrets to version control.
# ============================================================================


# Authentication --------------------------------------------------------------

# Secret used to sign JWTs.
# Generate a secure random value for real usage.
# Minimum recommended length: 32+ random characters.
JWT_SECRET=replace_with_a_long_random_jwt_secret

# Secret used to sign and verify HTTP cookies.
# Must be different from JWT_SECRET.
# Minimum recommended length: 32+ random characters.
COOKIE_SECRET=replace_with_a_different_long_random_cookie_secret

# JWT lifetime in seconds.
#
# Examples:
#   300    = 5 minutes
#   900    = 15 minutes
#   3600   = 1 hour
#   86400  = 1 day
JWT_EXPIRE=400


# Database --------------------------------------------------------------------

# PostgreSQL connection string.
#
# Format:
# postgres://<user>:<password>@<host>:<port>/<database>
#
# Example:
# postgres://depod:password@localhost:5432/depod
DATABASE_URL=postgres://depod:password@localhost:5432/depod


# Email -----------------------------------------------------------------------

# SMTP password or application password.
#
# Never use your real email account password if your provider supports
# application-specific passwords.
SMTP_PASS=replace_with_your_smtp_password


# TLS -------------------------------------------------------------------------

# Path to the TLS certificate (PEM format).
#
# Development:
#   ./cert.pem
#
# Production:
#   /etc/ssl/depod/fullchain.pem
TLS_CERT=./cert.pem

# Path to the TLS private key (PEM format).
#
# Development:
#   ./key.pem
#
# Production:
#   /etc/ssl/depod/privkey.pem
TLS_KEY=./key.pem


# Application -----------------------------------------------------------------

# Application domain.
DOMAIN=example.com
